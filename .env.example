# Database
DATABASE_URL="postgresql://user:password@localhost:5432/toolverse?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/toolverse?schema=public"

# Authentication
AUTH_SECRET="your-secret-here"
# Use the stable Vercel project URL while testing; switch to https://exismic.xyz at launch.
AUTH_URL="https://your-project.vercel.app"
AUTH_GOOGLE_ID="your-google-id"
AUTH_GOOGLE_SECRET="your-google-secret"
AUTH_DISCORD_ID="your-discord-id"
AUTH_DISCORD_SECRET="your-discord-secret"
ADMIN_EMAILS="your-admin-email@example.com"

# Supabase authentication and server-side data access
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Transactional email
RESEND_API_KEY="re_..."
# Must already be verified in Resend. Switch to exismic.xyz after its DNS is verified there.
EMAIL_SENDER_DOMAIN="your-verified-sender-domain.com"
DISCORD_SUPPORT_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# AI providers
GROQ_API_KEY="your-groq-key"
GROQ_API_KEYS="optional-comma-separated-key-pool"

# Background phone approval (generate with: npx web-push generate-vapid-keys --json)
# For Vercel testing, use the stable project URL (for example https://your-project.vercel.app).
# Change this to https://exismic.xyz only after the domain is connected and serving HTTPS.
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"
# Keep false on every preview and while testing on the Vercel URL.
SEO_INDEXING_ENABLED="false"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:your-admin-email@example.com"

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Modal heavy-task workers
MODAL_IMAGE_URL="https://your-current-bg-worker.modal.run"
MODAL_IMAGE_API_KEY="your-current-bg-worker-key"
MODAL_IMAGE_NORMAL_URL="https://your-normal-bg-worker.modal.run"
MODAL_IMAGE_NORMAL_API_KEY="your-normal-bg-worker-key"
MODAL_IMAGE_PRIORITY_URL="https://your-priority-bg-worker.modal.run"
MODAL_IMAGE_PRIORITY_API_KEY="your-priority-bg-worker-key"
MODAL_VIDEO_ENHANCER_URL="https://your-current-video-worker.modal.run"
MODAL_VIDEO_ENHANCER_NORMAL_URL="https://your-normal-video-worker.modal.run"
MODAL_VIDEO_ENHANCER_PRIORITY_URL="https://your-priority-video-worker.modal.run"

# Payments
NEXT_PUBLIC_PAYMENTS_ENABLED="false"
# Match NEXT_PUBLIC_SITE_URL during testing; change both together at launch.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# Razorpay (India / INR). Use matching test keys locally and matching live keys in production.
RAZORPAY_KEY_ID="rzp_test_or_live_..."
RAZORPAY_KEY_SECRET="..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_or_live_..."
RAZORPAY_PRO_PLAN_ID_INR="plan_..."
RAZORPAY_WEBHOOK_SECRET="use-a-unique-webhook-secret"

# PayPal (international / USD)
PAYPAL_MODE="live"
NEXT_PUBLIC_PAYPAL_SANDBOX_ENABLED="false"
PAYPAL_SANDBOX_ENABLED="false"
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."
NEXT_PUBLIC_PAYPAL_CLIENT_ID="..."
PAYPAL_PRO_PLAN_ID_USD="P-..."
PAYPAL_SANDBOX_WEBHOOK_ID=""
# Production uses the live webhook ID created for https://exismic.xyz/api/webhooks/paypal.
PAYPAL_WEBHOOK_ID="..."

# Billing jobs
CRON_SECRET="generate-a-long-random-secret"

# Local development only. Never set either variable to mock in production.
EXISMIC_LOCAL_PAYMENTS="off"
LOCAL_PAYMENT_MODE="off"
